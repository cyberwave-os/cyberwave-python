# Copy to .env and fill in your credentials.

CYBERWAVE_API_KEY=your_api_key_here
CYBERWAVE_MQTT_USERNAME=your_email@example.com

# Uncomment to target a non-production environment:
# CYBERWAVE_BASE_URL=https://api-dev.cyberwave.com

# MuJoCo OpenGL backend — auto-selected by the script (Linux→egl, macOS→cgl).
# Override here only if the default doesn't work on your system:
#   Linux/NVIDIA:  MUJOCO_GL=egl   (default)
#   Linux/display: MUJOCO_GL=glfw
#   macOS:         MUJOCO_GL=cgl   (default)
# MUJOCO_GL=egl
