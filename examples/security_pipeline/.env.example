# UUIDs of the two camera twins this worker anonymises.
CAMERA_1_TWIN=00000000-0000-0000-0000-000000000001
CAMERA_2_TWIN=00000000-0000-0000-0000-000000000002

# Cyberwave API key for the worker to load the model from the catalog.
CYBERWAVE_API_KEY=

# ── Driver-side configuration ────────────────────────────────────────
# Set these on each generic-camera driver container/twin (NOT here).
# Reproduced below for operator convenience so you can see the full
# picture at a glance.
#
# Required to enable the frame filter on a given twin:
#   CYBERWAVE_METADATA_FRAME_FILTER_ENABLED=true
#
# Optional freshness override (default 200 ms, tuned for ≥ 5 Hz GPU
# workers). Raise for CPU-only workers (e.g. 400–500 ms) at the cost
# of keeping visibly-stale anonymised frames on screen longer. `0`
# forces every frame to blank (useful as a fail-close test mode).
# Malformed values fall back to the default with a warning.
#   CYBERWAVE_METADATA_FRAME_FILTER_FRESHNESS_MS=200
#
# Channel name (``frames/filtered``) and fallback behaviour are
# hard-coded in the driver — not env-configurable. When the worker is
# down or stale the driver emits a black frame (fail-closed by
# design); to see the raw camera feed, set FRAME_FILTER_ENABLED=false
# and restart the driver.
#
# Note: when CYBERWAVE_DETECTION_OVERLAYS is left at its default
# (``true``), bounding boxes and labels are drawn on top of the
# anonymised frame and reveal each person's position. Set it to
# ``false`` on privacy-sensitive deployments.
